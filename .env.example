# Supabase Configuration
# Get these values from your Supabase project settings:
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Gmail OAuth (Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Encryption key for Gmail tokens (generate a random 32+ char string)
TOKEN_ENCRYPTION_SECRET=your-strong-random-encryption-key
